# Bali (Sepolia → Miden testnet) — Igor's deployment
#
# Non-secret config only. Secrets (private key, RPC URLs with API keys,
# claimer seed) go in `.env.local` next to this file (gitignored).
# `.env.local` overrides anything here when both are sourced.

# ── L1 (Sepolia) — bridge contracts from Igor's manifest ─────────────────────
SEPOLIA_CHAIN_ID=11155111
BRIDGE_ADDRESS="0x1348947e282138d8f377b467f7d9c2eb0f335d1f"
GLOBAL_EXIT_ROOT_ADDRESS="0x2968d6d736178f8fe7393cc33c87f29d9c287e78"
ROLLUP_MANAGER_ADDRESS="0xe2ef6215adc132df6913c8dd16487abf118d1764"
POL_TOKEN_ADDRESS="0x57e7e56d9dce34c5e899141834bf512061dd9cd0"
ROLLUP_ADDRESS="0x0f3961c855fd32ab3ed4de1ef843758e4805e5b7"
GAS_TOKEN_ADDRESS="0x0000000000000000000000000000000000000000"

# Sepolia public RPC fallback — works without an API key. Override with your
# own Infura/Alchemy URL in .env.local for higher rate limits.
SEPOLIA_RPC_URL="${SEPOLIA_RPC_URL:-https://ethereum-sepolia-rpc.publicnode.com}"

# ── L2 (Miden) ───────────────────────────────────────────────────────────────
DEST_NETWORK=73                              # rollupID for Miden in this deployment
L2_CHAIN_ID=1259691107
L2_RPC="https://miden-agglayer.dev.eu-north-3.gateway.fm"

# Miden node gRPC. Default is the public testnet RPC — works from any machine,
# no auth needed. If you want to hit the gateway.fm-fronted node you'll need
# the auth-header support that's still in-flight (miden-agglayer PR #29 +
# upstream miden-client PR #2101).
MIDEN_RPC_URL="${MIDEN_RPC_URL:-https://rpc.testnet.miden.io:443}"

# Alternative: gateway.fm path (rate-limited without auth header)
#   MIDEN_RPC_URL="https://miden-testnet.eu-central-8.gateway.fm:443"

# ── Observability ────────────────────────────────────────────────────────────
GRAFANA_BASE_URL="https://grafana.dev.eu-north-3.gateway.fm"
LOKI_NAMESPACE="outpost-testnet-miden-testnet"
LOKI_SERVICE="miden-agglayer"
LOKI_DATASOURCE_UID="P8E80F9AEF21F6940"

# ── Tooling paths ────────────────────────────────────────────────────────────
GATEWAY_MIDEN_DIR="${GATEWAY_MIDEN_DIR:-/Users/max/github/work/gateway/miden}"
# Bundled claim-note binary inside this skill. Built against miden-client v0.14.4
# (matches the pin in this repo's Cargo.toml). The old path in aggkit-proxy was
# alpha.1-era (Falcon512Rpo) and is NOT compatible with the Poseidon2 testnet
# node — do not switch back without bumping aggkit-proxy first.
SKILL_DIR="${SKILL_DIR:-${GATEWAY_MIDEN_DIR}/miden-agglayer/.claude/skills/test-bridging}"
CLAIM_NOTE_BIN="${SKILL_DIR}/claim-note/target/release/claim-note"
DEPOSIT_SCRIPT="${GATEWAY_MIDEN_DIR}/bali-l1-deposit.sh"
L2_STATUS_SCRIPT="${GATEWAY_MIDEN_DIR}/bali-l2-status.sh"

# ── Defaults ─────────────────────────────────────────────────────────────────
AMOUNT_ETH="${AMOUNT_ETH:-0.001}"
GAS_BUFFER_ETH="${GAS_BUFFER_ETH:-0.005}"
DRY_RUN="${DRY_RUN:-1}"

# ── Required secrets (must be set in .env.local or shell) ────────────────────
# SEPOLIA_RPC_URL is now defaulted to a public node above; override only if needed.
# FUNDER_PRIVATE_KEY=0x...                   # YOUR funded Sepolia EOA — only used to top up
#                                            # the disposable bridge wallet (below).
# CLAIMER_SEED="some long unique phrase"     # deterministic Miden account derivation
#
# Auto-generated by scripts/fund-bridge-wallet.sh on first run, persisted to .env.local:
# BRIDGE_WALLET_PRIVATE_KEY=0x...            # disposable EOA the deposit is broadcast from
