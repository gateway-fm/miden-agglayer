# Bali (Miden testnet → Sepolia) — L2→L1 bridge-out test env.
#
# Shares most values with test-bridging's bali.env. Kept separate so each
# skill can evolve independently (e.g. different default amounts).
#
# Secrets and the Miden bridge account ID go in `.env.local` (gitignored).

# ── L2 (Miden) ───────────────────────────────────────────────────────────────
L2_CHAIN_ID=1259691107
L2_NETWORK_ID=73
L2_RPC="https://miden-agglayer.dev.eu-north-3.gateway.fm"
MIDEN_RPC_URL="${MIDEN_RPC_URL:-https://rpc.testnet.miden.io:443}"

# ── L1 (Sepolia) ─────────────────────────────────────────────────────────────
SEPOLIA_CHAIN_ID=11155111
BRIDGE_ADDRESS="0x1348947e282138d8f377b467f7d9c2eb0f335d1f"
GLOBAL_EXIT_ROOT_ADDRESS="0x2968d6d736178f8fe7393cc33c87f29d9c287e78"
SEPOLIA_RPC_URL="${SEPOLIA_RPC_URL:-https://ethereum-sepolia-rpc.publicnode.com}"

# ── Observability ────────────────────────────────────────────────────────────
GRAFANA_BASE_URL="https://grafana.dev.eu-north-3.gateway.fm"
LOKI_NAMESPACE="outpost-testnet-miden-testnet"
LOKI_SERVICE="miden-agglayer"
LOKI_DATASOURCE_UID="P8E80F9AEF21F6940"

# ── Tooling paths ────────────────────────────────────────────────────────────
GATEWAY_MIDEN_DIR="${GATEWAY_MIDEN_DIR:-/Users/max/github/work/gateway/miden}"
SKILL_DIR="${SKILL_DIR:-${GATEWAY_MIDEN_DIR}/miden-agglayer/.claude/skills/test-bridging-out}"

# The bridge-out tool is a bin target of the miden-agglayer crate itself
# (src/bin/bridge_out_tool.rs). Built against the in-repo v0.14.4 pin, so it
# stays in sync with the deployed service's protocol automatically.
BRIDGE_OUT_BIN="${GATEWAY_MIDEN_DIR}/miden-agglayer/target/release/bridge-out-tool"

# The bundled claim-note binary from /test-bridging. Reused here to derive
# the wallet address + provide a ready-to-go miden-client store.
CLAIM_NOTE_BIN="${GATEWAY_MIDEN_DIR}/miden-agglayer/.claude/skills/test-bridging/claim-note/target/release/claim-note"

# ── Defaults ─────────────────────────────────────────────────────────────────
# Amount to bridge out, in *Miden units* (scale=10 for ETH → 10000 units = 0.0001 ETH on L1)
BRIDGE_OUT_AMOUNT="${BRIDGE_OUT_AMOUNT:-10000}"

# L1 destination of the bridge-out. Default is a placeholder so dry-runs don't
# accidentally send funds to a real random address — set this in .env.local.
DEST_L1_ADDRESS="${DEST_L1_ADDRESS:-0x0000000000000000000000000000000000000000}"

# Destination network (0 = Ethereum L1 in this agglayer deployment)
DEST_NETWORK="${DEST_NETWORK:-0}"

DRY_RUN="${DRY_RUN:-1}"

# ── Required config (set in .env.local or shell) ─────────────────────────────
# CLAIMER_SEED="same phrase used for /test-bridging"   — derives the sender wallet
#
# MIDEN_BRIDGE_ID="0x<30-hex>"        — the bridge account on Miden. Not
#                                       discoverable from any public endpoint
#                                       right now; ask the operator (Igor) or
#                                       extract from the agglayer pod's
#                                       /var/lib/miden-agglayer-service/bridge_accounts.toml
#
# MIDEN_FAUCET_ID="0xa88a59eb97990060612bc4a6c2f0dc"   — the ETH faucet on Miden.
#                                       Auto-captured from /test-bridging's last run
#                                       (in /tmp/claim-consume-final.out), or see the
#                                       skill README.
