# The MASM code of the AggLayer Faucet Account Component.
#
# This is a thin wrapper that re-exports faucet-related procedures from the agglayer library.
#
# The faucet exposes:
# - `mint_and_send` from the fungible faucet (for MINT note consumption, with owner verification
#   gated by the active mint policy)
# - `receive_and_burn` for bridge-out

pub use ::agglayer::faucet::mint_and_send
pub use ::agglayer::faucet::receive_and_burn
